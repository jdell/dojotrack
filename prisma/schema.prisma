// DojoTrack database schema.
//
// PostgreSQL on Supabase. Follows the mensajeras reference convention:
// a driver adapter (`@prisma/adapter-pg`) supplies the runtime connection, so
// the datasource carries no `url` here — `prisma.config.ts` provides DIRECT_URL
// for migrate/generate. Columns and tables map to snake_case for Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  INSTRUCTOR
  STUDENT
  PARENT
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
}

/// Day a recurring class meets. Mapped to JS `Date.getDay()` in code.
enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

/// Skill level a class targets.
enum ClassLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  ALL_LEVELS
}

/// State of a student's spot in a class session.
enum BookingStatus {
  BOOKED
  CANCELLED
  WAITLISTED
}

/// How a student's attendance was recorded.
enum CheckinMethod {
  QR_SCAN
  MANUAL
}

/// What kind of bar a `BeltRequirement` sets for the next rank. TIME and
/// CLASSES are auto-computed from data; TECHNIQUE/COMPETITION/CUSTOM are graded
/// manually by an instructor (tracked via `StudentTechniqueLog`).
enum RequirementType {
  TIME
  CLASSES
  TECHNIQUE
  COMPETITION
  CUSTOM
}

/// An instructor's assessment of a student against a manual requirement.
enum TechniqueStatus {
  NOT_ASSESSED
  IN_PROGRESS
  PASSED
}

/// Lifecycle of a grading exam.
enum ExamStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

/// A candidate's outcome at a grading exam.
enum CandidateResult {
  PENDING
  PASS
  FAIL
}

/// A martial arts club / dojo — the top-level tenant.
model Club {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  address      String?
  city         String?
  country      String?
  phone        String?
  email        String?
  description  String?
  logoUrl      String?  @map("logo_url")
  disciplines  String[]
  beltSystemId String?  @map("belt_system_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  users          User[]
  students       Student[]
  families       Family[]
  beltRanks      BeltRank[]
  invitations    Invitation[]
  classSchedules ClassSchedule[]
  gradingExams   GradingExam[]

  @@map("clubs")
}

/// An authenticated account (Supabase-backed). Owners/instructors run a club;
/// students/parents are linked to their `Student` records.
model User {
  id        String   @id @default(uuid())
  authId    String   @unique @map("auth_id")
  fullName  String?  @map("full_name")
  phone     String?
  email     String?
  role      Role     @default(STUDENT)
  clubId    String?  @map("club_id")
  createdAt DateTime @default(now()) @map("created_at")

  club               Club?                 @relation(fields: [clubId], references: [id])
  students           Student[]
  instructingClasses ClassSchedule[]       @relation("ClassInstructor")
  substituteSessions ClassSession[]        @relation("SessionSubstitute")
  assessedTechniques StudentTechniqueLog[] @relation("TechniqueAssessor")

  @@index([clubId])
  @@map("users")
}

/// An enrolled member of a club. May be linked to a `User` account (adult
/// members) or stand alone (children managed under a family).
model Student {
  id               String    @id @default(uuid())
  clubId           String    @map("club_id")
  userId           String?   @map("user_id")
  fullName         String    @map("full_name")
  phone            String?
  email            String?
  beltRankId       String?   @map("belt_rank_id")
  joinDate         DateTime  @default(now()) @map("join_date")
  dateOfBirth      DateTime? @map("date_of_birth")
  medicalNotes     String?   @map("medical_notes")
  emergencyContact String?   @map("emergency_contact")
  emergencyPhone   String?   @map("emergency_phone")
  familyId         String?   @map("family_id")
  active           Boolean   @default(true)
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  club          Club                  @relation(fields: [clubId], references: [id])
  user          User?                 @relation(fields: [userId], references: [id])
  beltRank      BeltRank?             @relation(fields: [beltRankId], references: [id])
  family        Family?               @relation(fields: [familyId], references: [id])
  bookings      Booking[]
  attendances   Attendance[]
  techniqueLogs StudentTechniqueLog[]
  candidacies   GradingCandidate[]

  @@index([clubId])
  @@index([familyId])
  @@map("students")
}

/// Groups related members (siblings, parent + child) for shared billing.
model Family {
  id        String   @id @default(uuid())
  name      String
  clubId    String   @map("club_id")
  createdAt DateTime @default(now()) @map("created_at")

  club     Club      @relation(fields: [clubId], references: [id])
  students Student[]

  @@index([clubId])
  @@map("families")
}

/// A single rank within a club's belt system.
model BeltRank {
  id         String   @id @default(uuid())
  clubId     String   @map("club_id")
  name       String
  color      String
  hexColor   String   @map("hex_color")
  order      Int
  minMonths  Int?     @map("min_months")
  minClasses Int?     @map("min_classes")
  createdAt  DateTime @default(now()) @map("created_at")

  club         Club               @relation(fields: [clubId], references: [id])
  students     Student[]
  requirements BeltRequirement[]
  examTargets  GradingExam[]      @relation("ExamTargetBelt")
  awardedTo    GradingCandidate[] @relation("CandidateNewBelt")

  @@index([clubId])
  @@map("belt_ranks")
}

/// A shareable, single-use link that invites someone to join a club.
model Invitation {
  id        String           @id @default(uuid())
  clubId    String           @map("club_id")
  token     String           @unique @default(uuid())
  unitLabel String?          @map("unit_label")
  status    InvitationStatus @default(PENDING)
  createdAt DateTime         @default(now()) @map("created_at")
  expiresAt DateTime?        @map("expires_at")

  club Club @relation(fields: [clubId], references: [id])

  @@index([clubId])
  @@map("invitations")
}

/// A recurring weekly class on a club's timetable. Concrete dated occurrences
/// are materialised as `ClassSession` rows lazily, when first needed.
model ClassSchedule {
  id           String     @id @default(uuid())
  clubId       String     @map("club_id")
  name         String
  discipline   String
  dayOfWeek    DayOfWeek  @map("day_of_week")
  startTime    String     @map("start_time")
  endTime      String     @map("end_time")
  instructorId String?    @map("instructor_id")
  maxStudents  Int        @map("max_students")
  location     String?
  level        ClassLevel @default(ALL_LEVELS)
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")

  club       Club           @relation(fields: [clubId], references: [id])
  instructor User?          @relation("ClassInstructor", fields: [instructorId], references: [id])
  sessions   ClassSession[]

  @@index([clubId])
  @@map("class_schedules")
}

/// A single dated occurrence of a recurring `ClassSchedule`. Unique per
/// (schedule, date) so it can be found-or-created idempotently.
model ClassSession {
  id                     String   @id @default(uuid())
  classScheduleId        String   @map("class_schedule_id")
  date                   DateTime
  cancelled              Boolean  @default(false)
  cancelReason           String?  @map("cancel_reason")
  substituteInstructorId String?  @map("substitute_instructor_id")
  createdAt              DateTime @default(now()) @map("created_at")

  classSchedule        ClassSchedule @relation(fields: [classScheduleId], references: [id], onDelete: Cascade)
  substituteInstructor User?         @relation("SessionSubstitute", fields: [substituteInstructorId], references: [id])
  bookings             Booking[]
  attendances          Attendance[]

  @@unique([classScheduleId, date])
  @@index([date])
  @@map("class_sessions")
}

/// A student's reservation for a class session. One row per (session, student);
/// cancelling flips the status rather than deleting, preserving history.
model Booking {
  id             String        @id @default(uuid())
  classSessionId String        @map("class_session_id")
  studentId      String        @map("student_id")
  status         BookingStatus @default(BOOKED)
  bookedAt       DateTime      @default(now()) @map("booked_at")
  cancelledAt    DateTime?     @map("cancelled_at")

  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([classSessionId, studentId])
  @@index([studentId])
  @@map("bookings")
}

/// A check-in record: a student physically attended a class session.
model Attendance {
  id             String        @id @default(uuid())
  classSessionId String        @map("class_session_id")
  studentId      String        @map("student_id")
  checkedInAt    DateTime      @default(now()) @map("checked_in_at")
  method         CheckinMethod @default(MANUAL)
  notes          String?

  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id])

  @@unique([classSessionId, studentId])
  @@index([studentId])
  @@map("attendances")
}

/// One bar a student must clear to earn a given belt rank. TIME/CLASSES carry a
/// numeric `targetValue` (months / class count) and are met automatically;
/// TECHNIQUE/COMPETITION/CUSTOM are graded by an instructor via
/// `StudentTechniqueLog`. Belongs to the rank being *earned*.
model BeltRequirement {
  id          String          @id @default(uuid())
  beltRankId  String          @map("belt_rank_id")
  name        String
  description String?
  type        RequirementType @default(TECHNIQUE)
  targetValue Int?            @map("target_value")
  order       Int             @default(0)
  createdAt   DateTime        @default(now()) @map("created_at")

  beltRank BeltRank              @relation(fields: [beltRankId], references: [id], onDelete: Cascade)
  logs     StudentTechniqueLog[]

  @@index([beltRankId])
  @@map("belt_requirements")
}

/// An instructor's running assessment of one student against one manual
/// requirement. One row per (student, requirement) so it can be upserted.
model StudentTechniqueLog {
  id                String          @id @default(uuid())
  studentId         String          @map("student_id")
  beltRequirementId String          @map("belt_requirement_id")
  status            TechniqueStatus @default(NOT_ASSESSED)
  assessedById      String?         @map("assessed_by_id")
  assessedAt        DateTime?       @map("assessed_at")
  notes             String?
  createdAt         DateTime        @default(now()) @map("created_at")

  student         Student         @relation(fields: [studentId], references: [id])
  beltRequirement BeltRequirement @relation(fields: [beltRequirementId], references: [id], onDelete: Cascade)
  assessedBy      User?           @relation("TechniqueAssessor", fields: [assessedById], references: [id])

  @@unique([studentId, beltRequirementId])
  @@index([studentId])
  @@index([beltRequirementId])
  @@map("student_technique_logs")
}

/// A scheduled grading where candidates test for `targetBeltRank`.
model GradingExam {
  id               String     @id @default(uuid())
  clubId           String     @map("club_id")
  targetBeltRankId String     @map("target_belt_rank_id")
  date             DateTime
  location         String?
  fee              Decimal?   @db.Decimal(10, 2)
  notes            String?
  status           ExamStatus @default(SCHEDULED)
  createdAt        DateTime   @default(now()) @map("created_at")

  club           Club               @relation(fields: [clubId], references: [id])
  targetBeltRank BeltRank           @relation("ExamTargetBelt", fields: [targetBeltRankId], references: [id])
  candidates     GradingCandidate[]

  @@index([clubId])
  @@map("grading_exams")
}

/// A student entered into a grading exam, plus their result. On a PASS the
/// student's belt is promoted and `newBeltRankId` records what they were
/// awarded (this doubles as the club's belt-promotion history).
model GradingCandidate {
  id              String          @id @default(uuid())
  examId          String          @map("exam_id")
  studentId       String          @map("student_id")
  result          CandidateResult @default(PENDING)
  techniquesScore Int?            @map("techniques_score")
  sparringPassed  Boolean?        @map("sparring_passed")
  notes           String?
  newBeltRankId   String?         @map("new_belt_rank_id")
  createdAt       DateTime        @default(now()) @map("created_at")

  exam        GradingExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     Student     @relation(fields: [studentId], references: [id])
  newBeltRank BeltRank?   @relation("CandidateNewBelt", fields: [newBeltRankId], references: [id])

  @@unique([examId, studentId])
  @@index([studentId])
  @@map("grading_candidates")
}
