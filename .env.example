NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_URL=http://localhost:3000

# ── Database (Supabase Postgres) ─────────────────────────────────────────────
# Pooled connection (port 6543) — used by the app at runtime via the adapter.
DATABASE_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used ONLY for prisma migrate / generate.
DIRECT_URL="postgresql://postgres.REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ── Payments (Stripe) ────────────────────────────────────────────────────────
# Server-side secret key. When unset, the payments dashboard renders an empty
# state and checkout/webhook routes return a friendly 503 (see src/lib/stripe.ts).
STRIPE_SECRET_KEY=
# Signing secret for the /api/webhooks/stripe endpoint (from the Stripe CLI or
# dashboard webhook config). Required to verify and process events.
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────────
# API key for transactional email (club invites, payment receipts, grading
# results). When unset, emails are logged to the server console instead — see
# src/lib/email.ts. Get one at https://resend.com/api-keys
RESEND_API_KEY=
# Optional "From" address. Defaults to onboarding@resend.dev (fine for testing);
# production should use a sender on a domain verified in Resend.
RESEND_FROM=

# ── WhatsApp (Meta WhatsApp Business / Graph API) ────────────────────────────
# Access token + phone-number id for WhatsApp notifications (class reminders,
# payment-due reminders, belt-exam notices). When unset, messages are logged to
# the console instead — see src/lib/notify.ts. From the Meta WhatsApp Business
# account: WHATSAPP_PHONE_ID is the "Phone number ID" on the API setup page.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=
